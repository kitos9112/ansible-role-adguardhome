# Cloudflare API credentials used by Certbot
{% if adguardhome_cf_api_token | default('') | trim | length > 0 %}
dns_cloudflare_api_token = {{ adguardhome_cf_api_token }}
{% else %}
dns_cloudflare_email = {{ adguardhome_cf_email_address }}
dns_cloudflare_api_key = {{ adguardhome_cf_api_key }}
{% endif %}
